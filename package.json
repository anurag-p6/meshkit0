{
  "name": "ipfs-meshkit",
  "version": "1.0.0",
  "private": true,
  "description": "IPFS Meshkit is a SDK for building IPFS applications.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "npm run clean --workspaces --if-present",
    "test": "npm run test:unit",
    "test:unit": "vitest run --project unit",
    "test:unit:watch": "vitest --project unit",
    "test:unit:coverage": "vitest run --project unit --coverage",
    "test:integration": "npm run build && vitest run --project integration",
    "test:all": "npm run build && vitest run",
    "test:ci": "npm run test:unit:coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seetadev/IPFS-meshkit.git"
  },
  "keywords": ["ipfs", "meshkit", "stack", "ionic"],
  "author": "Manu Sheel Gupta",
  "contributors": [
    {
      "name": "Anurag Pandey",
      "url": "https://github.com/anurag-p6"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/seetadev/IPFS-meshkit/issues"
  },
  "homepage": "https://github.com/seetadev/IPFS-meshkit#readme",
  "devDependencies": {
    "@ipfs-meshkit/meshkit": "*",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
