{
  "name": "ipfs-meshkit",
  "version": "1.0.0",
  "private": true,
  "description": "IPFS Meshkit is a SDK for building IPFS applications.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "npm run clean --workspaces --if-present",
    "test:persistence": "npm run test:persistence --workspace=meshkit-dummy-app",
    "test:ipns": "npm run test:ipns --workspace=meshkit-dummy-app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seetadev/IPFS-meshkit.git"
  },
  "keywords": ["ipfs", "meshkit", "stack", "ionic"],
  "author": "Manu Sheel Gupta",
  "contributors": [
    {
      "name": "Anurag Pandey",
      "url": "https://github.com/anurag-p6"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/seetadev/IPFS-meshkit/issues"
  },
  "homepage": "https://github.com/seetadev/IPFS-meshkit#readme",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
